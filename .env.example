# ================================================
# IPPMIFY - Variaveis de Ambiente
# INSTRUCAO: Copie este arquivo, renomeie para .env
# e preencha com seus dados reais
# ================================================

# SERVIDOR
PORT=3000
NODE_ENV=production

# SEGURANCA (gere uma chave aleatoria em: https://generate-secret.vercel.app/64)
JWT_SECRET=COLE_AQUI_UMA_CHAVE_SECRETA_LONGA
ENCRYPTION_KEY=COLE_AQUI_OUTRA_CHAVE_DE_32_CARACTERES

# BANCO DE DADOS - SUPABASE
# Pegue em: Supabase > Settings > Database > Connection string (URI)
DATABASE_URL=postgresql://postgres:[SUA-SENHA]@db.[SEU-ID].supabase.co:5432/postgres

# REDIS - UPSTASH
# Pegue em: Upstash > Seu banco > Details > UPSTASH_REDIS_REST_URL
REDIS_URL=redis://:[SUA-SENHA]@[SEU-HOST].upstash.io:6379

# OPENAI
# Pegue em: platform.openai.com > API Keys
OPENAI_API_KEY=sk-...

# META ADS (Facebook)
# Pegue em: developers.facebook.com > Seu App
META_APP_ID=SEU_APP_ID
META_APP_SECRET=SEU_APP_SECRET
META_REDIRECT_URI=https://SEU-DOMINIO.railway.app/api/integrations/meta-ads/callback

# TWILIO (WhatsApp)
# Pegue em: console.twilio.com
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# SENDGRID (Email)
# Pegue em: app.sendgrid.com > Settings > API Keys
SENDGRID_API_KEY=SG...
EMAIL_FROM=noreply@seudominio.com

# URL DO APP (preenchida automaticamente pelo Railway)
APP_URL=https://SEU-DOMINIO.railway.app
